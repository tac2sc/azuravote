PORT=3099
NODE_ENV=production
DATABASE_PATH=/data/votes.sqlite
AZURAVOTE_CPU_LIMIT=0.5
AZURAVOTE_MEMORY_LIMIT=256m

AZURACAST_BASE_URL=https://radio.example.com
AZURACAST_STATION_ID=1
AZURACAST_STATION_SHORT_NAME=my_station
AZURACAST_API_KEY=

PUBLIC_BASE_URL=https://radio.example.com/votes

VOTER_HASH_SECRET=change-this-long-random-secret
TRUST_PROXY=true

CORS_ALLOWED_ORIGINS=https://radio.example.com
WIDGET_THEME=dark
HIDE_PUBLIC_DOWNVOTES=false
WIDGET_PUBLIC_PATH=/widget
EMBED_SCRIPT_PATH=/embed.js

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_VOTES=20

# Optional AzuraCast playlist/media sync.
# Dry-run: npm run sync:rotation
# Apply: npm run sync:rotation:apply
ROTATION_HIGH_SCORE=2
ROTATION_LOW_SCORE=-2
ROTATION_BLOCK_DAYS=7
AZURACAST_HIGH_PLAYLIST_ID=2
AZURACAST_LOW_PLAYLIST_ID=3
